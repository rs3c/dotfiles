      "keyColor": "blue"
    },
    {
      "type": "terminalfont",
      "key": " \uf031  Font",
      "keyColor": "blue"
    },
    {
      "type": "packages",
      "key": " \uf487  Packages",
      "keyColor": "blue"
    },
    {
      "type": "custom",
      "format": "\u001b[36m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ"
