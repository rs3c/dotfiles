{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "kitty",
    "source": "~/.cache/current_wallpaper",
    "width": 30,
    "height": 16,
    "preserveAspectRatio": true,
    "padding": {
      "top": 1,
      "right": 2
    }
  },
  "display": {
    "separator": "  ",
    "color": {
      "keys": "blue"
    }
  },
  "modules": [
    "title",
    {
      "type": "custom",
      "format": "\u001b[34m‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ"
    },
    {
      "type": "os",
      "key": " \udb82\udcc7  OS",
      "keyColor": "blue"
    },
    {
      "type": "kernel",
      "key": " \ue712  Kernel",
      "keyColor": "blue"
    },
    {
      "type": "uptime",
      "key": " \uf017  Uptime",
      "keyColor": "blue"
    },
    {
